<% content_for :title, "Search" %>
<%= turbo_stream_from :search %>

<main class="search">
  <%= form_with url: search_path, method: :post, class: "search__form" do |f| %>
    <%= f.label :q, "Query", class: "search__label" %>
    <%= f.search_field :q,
                       value: params[:q],
                       placeholder: "e.g. blue running shoes size 10",
                       autofocus: true,
                       class: "search__input" %>
    <%= f.submit "Go", class: "search__submit" %>
  <% end %>

  <section class="results" aria-live="polite">
    <% [
         { key: "youtube",     name: "YouTube" },
         { key: "reddit",      name: "Reddit" },
         { key: "hacker_news", name: "Hacker News" }
       ].each do |source| %>
      <article id="<%= source[:key] %>" class="panel panel--pending panel--<%= source[:key] %>" data-source="<%= source[:key] %>">
        <header class="panel__head">
          <h2 class="panel__title"><%= source[:name] %></h2>
          <span class="panel__status" data-state="launching">
            <span class="panel__spinner" aria-hidden="true"></span>
          </span>
        </header>
        <div id="<%= source[:key] %>-results"></div>
      </article>
    <% end %>
  </section>
</main>
